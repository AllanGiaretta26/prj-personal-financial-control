# ─────────────────────────────────────────────────────────────────────────────
# Exemplo de variáveis de ambiente — Personal Financial Control
#
# Copie para `.env` (gitignored) e ajuste, OU configure cada variável no painel
# do provedor de deploy (ex.: Render). NUNCA comite segredos reais.
#
# O perfil `local` (application-local.yaml) já traz valores de conveniência para
# desenvolvimento, então rodar localmente NÃO exige preencher este arquivo —
# ele documenta o que o perfil padrão (produção) espera.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados — role de runtime de privilégio mínimo (sem DDL) ──
# Usada por spring.datasource.* (apenas SELECT/INSERT/UPDATE/DELETE).
DB_URL=jdbc:postgresql://localhost:5432/pfc
DB_USERNAME=pfc_app
DB_PASSWORD=troque-este-valor

# ── Banco de dados — role dona do schema (DDL), usada SÓ pelo Flyway ──
# FLYWAY_URL é opcional: se omitido, usa DB_URL.
FLYWAY_URL=jdbc:postgresql://localhost:5432/pfc
FLYWAY_USERNAME=pfc
FLYWAY_PASSWORD=troque-este-valor

# ── JWT ──
# Segredo HMAC-SHA256: mínimo 32 caracteres (256 bits). Gere um valor aleatório
# forte e único por ambiente (ex.: `openssl rand -base64 48`).
JWT_SECRET=gere-um-segredo-aleatorio-com-no-minimo-32-caracteres
# Validade do token em milissegundos (padrão 3600000 = 1 hora).
JWT_EXPIRATION_MS=3600000

# ── CORS ──
# Origens permitidas do frontend, separadas por vírgula. NUNCA use "*".
# Em produção, aponte para o(s) domínio(s) reais do frontend.
CORS_ALLOWED_ORIGINS=http://localhost:*

# ── Rate limiting (opcional — têm padrões no application.yaml) ──
# Rotas de auth (por IP, anti-força-bruta): padrão 5 req/min.
RATE_LIMIT_LOGIN_CAPACITY=5
RATE_LIMIT_LOGIN_REFILL_TOKENS=5
RATE_LIMIT_LOGIN_REFILL_PERIOD_SECONDS=60
# Demais rotas (por usuário autenticado): padrão 60 req/min.
RATE_LIMIT_DEFAULT_CAPACITY=60
RATE_LIMIT_DEFAULT_REFILL_TOKENS=60
RATE_LIMIT_DEFAULT_REFILL_PERIOD_SECONDS=60

# ── Docker Compose local (docker-compose.yml) ──
# Credenciais da role dona criada na 1ª inicialização do container Postgres.
POSTGRES_DB=pfc
POSTGRES_USER=pfc
POSTGRES_PASSWORD=pfc
